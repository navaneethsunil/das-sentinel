# DAS Sentinel — environment template (M0-I3).
# Copy to `.env` and fill in values. PLACEHOLDERS ONLY in this file — never commit
# real secrets (CLAUDE.md §5, TRD TR-23). `.env` is gitignored.
#
# docker compose reads this file automatically; the API/worker load the same vars
# through the single `Settings` object in `apps/api/app/core/config.py`.

# ─── App ────────────────────────────────────────────────────────────────────
# dev | test | prod
DAS_ENV=dev
LOG_LEVEL=INFO
# FastAPI root_path behind the Caddy proxy (M0-B1 / M0-I4)
API_ROOT_PATH=/api
# argon2id (OWASP default) | pbkdf2_sha256 (FIPS fallback — flip only if the
# target ATO mandates FIPS-validated password storage; existing hashes keep
# verifying and upgrade on next login) (M1-B1)
PASSWORD_HASH_SCHEME=argon2id

# ─── PostgreSQL (compose service `postgres` + API) ──────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=dassentinel
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dassentinel

# ─── Valkey (compose service `valkey`) ──────────────────────────────────────
# Celery URLs use the redis:// scheme (protocol-compatible — M0-W1).
VALKEY_HOST=valkey
VALKEY_PORT=6379
# Separate logical DBs: broker / results / cache / sessions (M0-W1, M1-B2)
VALKEY_DB_BROKER=0
VALKEY_DB_RESULTS=1
VALKEY_DB_CACHE=2
VALKEY_DB_SESSIONS=3

# ─── MinIO — DEV-ONLY evidence store (ROADMAP evidence-backend gate) ────────
# Image tag for compose; digest-pin is tracked as TR-25 follow-up.
MINIO_IMAGE_TAG=latest
# Server root credentials (compose service `minio`)
MINIO_ROOT_USER=dassentinel
MINIO_ROOT_PASSWORD=change-me
# API-side client config; internal endpoint, plaintext inside the compose network
MINIO_ENDPOINT=minio:9000
MINIO_SECURE=false
EVIDENCE_BUCKET=evidence
# Optional scoped client credentials for the API — if unset, the Settings object
# falls back to the root credentials above (acceptable in dev only).
#MINIO_ACCESS_KEY=
#MINIO_SECRET_KEY=

# ─── Web (compose service `web`) ────────────────────────────────────────────
# Server-side (RSC) API base — compose-internal, never exposed to the browser.
# Browser requests go same-origin via the proxy (/api → api, M0-I4).
API_INTERNAL_URL=http://api:8000

# ─── LLM (provider abstraction — CLAUDE.md §7; wired in M2) ─────────────────
# anthropic | ollama | vllm
LLM_PROVIDER=anthropic
# Required only when LLM_PROVIDER=anthropic; leave empty otherwise.
ANTHROPIC_API_KEY=
# Model routing (no model names hardcoded in code)
LLM_MODEL_DEFAULT=claude-opus-4-8
LLM_MODEL_TRIAGE=claude-sonnet-5
LLM_MODEL_CLASSIFIER=claude-haiku-4-5
# Local backends (optional; required when the matching LLM_PROVIDER is selected)
#OLLAMA_BASE_URL=http://ollama:11434
#VLLM_BASE_URL=http://vllm:8000
